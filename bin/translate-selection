#!/bin/bash
set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
export LANG="ja_JP.UTF-8"
export LC_ALL="ja_JP.UTF-8"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "$SCRIPT_DIR/lib/selection.sh"

notify_translation() {
    /usr/bin/osascript - "$1" <<'APPLESCRIPT'
on run argv
    display notification (item 1 of argv) with title "Auto Translate EN↔JP"
end run
APPLESCRIPT
}

set_clipboard_fallback() {
    /usr/bin/osascript - "$1" <<'APPLESCRIPT'
on run argv
    set the clipboard to (item 1 of argv)
end run
APPLESCRIPT
}

if [ "${1:-}" = "--from-clipboard" ]; then
    text="$(pbpaste)"
else
    text="$(copy_selection_to_clipboard || true)"
fi

if [ -z "$text" ]; then
    echo "選択テキストをコピーできませんでした"
    exit 1
fi

if echo "$text" | grep -qE '[ぁ-んァ-ヶー一-龠０-９]'; then
    translation="$(/opt/homebrew/bin/trans -brief ja:en "$text" 2>/dev/null)"
    echo "→ English"
else
    translation="$(/opt/homebrew/bin/trans -brief en:ja "$text" 2>/dev/null)"
    echo "→ 日本語"
fi

if [ -z "$translation" ]; then
    echo "翻訳に失敗しました"
    exit 1
fi

printf '%s' "$translation" | /usr/bin/pbcopy

if [ "$(/usr/bin/pbpaste)" != "$translation" ]; then
    set_clipboard_fallback "$translation"
fi

notification_text="$(printf '%s' "$translation" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')"
notification_text="$(
    /usr/bin/python3 -c 'import sys; print(sys.argv[1][:140])' "$notification_text"
)"

notify_translation "$notification_text"
