#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "$SCRIPT_DIR/lib/selection.sh"

if [ "${1:-}" = "--from-clipboard" ]; then
  term="$(pbpaste | tr '\n' ' ' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
else
  term="$(copy_selection_to_clipboard | tr '\n' ' ' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
fi

if [ -z "$term" ]; then
  echo "選択テキストをコピーできませんでした"
  exit 1
fi

encoded_term=$(/usr/bin/python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1]))' "$term")

/usr/bin/open "dict:///$encoded_term"
